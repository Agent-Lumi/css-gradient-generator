<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSS Gradient Generator</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>🎨 CSS Gradient Generator</h1>
        <p class="subtitle">Create beautiful CSS gradients with live preview</p>
        
        <div class="gradient-preview" id="preview"></div>
        
        <div class="controls">
            <div class="control-group">
                <label>Gradient Type</label>
                <select id="gradientType">
                    <option value="linear">Linear</option>
                    <option value="radial">Radial</option>
                    <option value="conic">Conic</option>
                </select>
            </div>
            
            <div class="control-group" id="angleControl">
                <label>Angle: <span id="angleValue">90</span>°</label>
                <input type="range" id="angle" min="0" max="360" value="90">
            </div>
            
            <div class="colors-section">
                <h3>Colors</h3>
                <div class="color-stops" id="colorStops">
                    <div class="color-stop">
                        <input type="color" class="color-picker" value="#667eea">
                        <input type="number" class="position" value="0" min="0" max="100">%
                    </div>
                    <div class="color-stop">
                        <input type="color" class="color-picker" value="#764ba2">
                        <input type="number" class="position" value="100" min="0" max="100">%
                    </div>
                </div>
                <button id="addColor" class="btn btn-secondary">+ Add Color</button>
            </div>
        </div>
        
        <div class="output-section">
            <h3>CSS Code</h3>
            <div class="code-block">
                <code id="cssCode">background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);</code>
                <button id="copyBtn" class="btn btn-copy">Copy</button>
            </div>
        </div>
        
        <div class="presets">
            <h3>Presets</h3>
            <div class="preset-grid" id="presets"></div>
        </div>
    </div>
    
    <script src="app.js"></script>
</body>
</html>
<script>
// Undo/Redo history
const history = { past: [], future: [] };
const saveState = () => {
    const state = document.querySelector('textarea, input')?.value;
    if (state) history.past.push(state);
};
document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') {
        e.preventDefault();
        if (e.shiftKey && history.future.length) {
            // Redo
            const state = history.future.pop();
            history.past.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        } else if (history.past.length) {
            // Undo
            const state = history.past.pop();
            history.future.push(document.querySelector('textarea, input')?.value);
            if (document.querySelector('textarea, input')) document.querySelector('textarea, input').value = state;
        }
    }
});
document.addEventListener('input', saveState);
</script>
<style>
@media (max-width: 768px) {
    .container { padding: 10px; }
    h1 { font-size: 1.5rem; }
    button { width: 100%; margin: 5px 0; }
}
</style>
<script>
// Import from file
const importBtn = document.createElement('button');
importBtn.textContent = '📁 Import';
importBtn.onclick = () => {
    const input = document.createElement('input');
    input.type = 'file';
    input.onchange = (e) => {
        const file = e.target.files[0];
        const reader = new FileReader();
        reader.onload = (e) => {
            const textArea = document.querySelector('textarea');
            if (textArea) textArea.value = e.target.result;
        };
        reader.readAsText(file);
    };
    input.click();
};
document.querySelector('.container')?.appendChild(importBtn);
</script>
<script>
// Auto-save to localStorage
const saveKey = 'app-data-' + location.pathname;
const saveData = () => {
    const data = { timestamp: Date.now(), inputs: {} };
    document.querySelectorAll('input, textarea').forEach(el => {
        data.inputs[el.id || el.name] = el.value;
    });
    localStorage.setItem(saveKey, JSON.stringify(data));
};
const loadData = () => {
    const saved = localStorage.getItem(saveKey);
    if (saved) {
        const data = JSON.parse(saved);
        Object.entries(data.inputs).forEach(([key, value]) => {
            const el = document.getElementById(key) || document.querySelector('[name="' + key + '"]');
            if (el) el.value = value;
        });
    }
};
document.addEventListener('input', saveData);
document.addEventListener('DOMContentLoaded', loadData);
</script>
